# Copy to .env.local for local dev, and set the same vars in Vercel project settings.

# Public (safe to expose) — these connect the app to your Sanity Content Lake.
NEXT_PUBLIC_SANITY_PROJECT_ID=bict0s25
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Server-only (NO NEXT_PUBLIC prefix). Never commit real values.
# Write token: used by the content import scripts only (not by the live site reads).
SANITY_API_WRITE_TOKEN=
# Shared secret for the Sanity publish webhook -> /api/revalidate (optional; enables instant updates).
SANITY_REVALIDATE_SECRET=
# Maximus CMS read API key (mxl_pk_...) for the blog sync. Local for the script;
# also add to Vercel if you want the auto-sync route /api/sync-blogs to run.
MXL_API_KEY=
# Auto-sync route secret. The Maxint publish-webhook calls /api/sync-blogs?secret=<this>.
SYNC_SECRET=
# Optional: set in Vercel to let a Vercel Cron call /api/sync-blogs (Vercel signs it).
CRON_SECRET=
